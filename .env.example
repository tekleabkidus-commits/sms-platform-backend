REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DB=0
KAFKA_CLIENT_ID=sms-platform-backend
KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=sms-platform-backend
