{
  "name": "sms-platform-backend",
  "version": "1.0.0",
  "description": "Carrier-grade multi-tenant SMS SaaS backend built with NestJS, Kafka, PostgreSQL, Redis, and SMPP connectors.",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/main.js",
    "start:prod": "node dist/src/main.js",
    "start:api": "node scripts/start-role.mjs api",
    "start:worker-dispatch": "node scripts/start-role.mjs worker-dispatch",
    "start:worker-dlr": "node scripts/start-role.mjs worker-dlr",
    "start:worker-outbox": "node scripts/start-role.mjs worker-outbox",
    "start:worker-campaign": "node scripts/start-role.mjs worker-campaign",
    "start:worker-fraud": "node scripts/start-role.mjs worker-fraud",
    "start:worker-reconciliation": "node scripts/start-role.mjs worker-reconciliation",
    "start:dev": "ts-node --project tsconfig.json src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:ci": "npm run test && npm run build",
    "validate:manifests": "node scripts/validate-manifests.mjs",
    "migrate": "node scripts/run-migrations.mjs",
    "seed:local": "node scripts/seed-local-admin.mjs",
    "seed:staging-users": "node scripts/seed-staging-test-users.mjs",
    "smoke": "node scripts/smoke-check.mjs",
    "verify": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/swagger": "^11.2.0",
    "axios": "^1.9.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cron-parser": "^5.2.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "joi": "^17.13.3",
    "kafkajs": "^2.2.4",
    "pg": "^8.16.0",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "smpp": "^0.6.0-rc.4"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.6",
    "@types/express": "^5.0.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.2",
    "@types/supertest": "^6.0.3",
    "jest": "^29.7.0",
    "supertest": "^7.1.1",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
