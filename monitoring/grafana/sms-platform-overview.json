{
  "title": "SMS Platform Overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "tags": ["sms-platform", "operations"],
  "timezone": "browser",
  "panels": [
    {
      "type": "timeseries",
      "title": "HTTP Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[5m])) by (status_code)",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HTTP P95 Latency",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Outbox Backlog",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(sms_outbox_backlog{status=\"pending\"})"
        }
      ]
    },
    {
      "type": "stat",
      "title": "DLR Backlog",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum(sms_dlr_backlog)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Reconciliation Backlog",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(sms_reconciliation_backlog)"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Rate Limit Denials / sec",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(sms_rate_limit_denied_total[5m]))"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Dispatch Attempts",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(sms_dispatch_attempts_total[5m])) by (provider, outcome)",
          "legendFormat": "{{provider}} {{outcome}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Provider Circuit State",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sms_provider_circuit_state",
          "legendFormat": "{{provider}} {{state}}"
        }
      ]
    }
  ]
}
