# Railway control-plane service variables
# Keep the API Railway service name as "api" if you want these references to work
# without editing.

NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
HOSTNAME=0.0.0.0

# Internal server-side BFF target.
BACKEND_BASE_URL=http://${{api.RAILWAY_PRIVATE_DOMAIN}}/api/v1

# Public docs link shown in the developer portal.
NEXT_PUBLIC_BACKEND_SWAGGER_URL=https://${{api.RAILWAY_PUBLIC_DOMAIN}}/api/v1/docs

# Current known backend public URL, if you prefer to paste the exact value instead
# of the Railway reference above:
# NEXT_PUBLIC_BACKEND_SWAGGER_URL=https://sms-platform-backend-production-103d.up.railway.app/api/v1/docs
